#include <graphics.h>
#include <stdio.h>
#include <conio.h>

int main()
{
    int gd = DETECT, gm;
    int x1, y1, x2, y2, xmin, ymin, xmax, ymax;
    int dx, dy, p[4], q[4], i;
    float t1 = 0.0, t2 = 1.0, t;

    printf("Enter xmin ymin xmax ymax: ");
    scanf("%d%d%d%d", &xmin, &ymin, &xmax, &ymax);

    printf("Enter line coordinates (x1 y1 x2 y2): ");
    scanf("%d%d%d%d", &x1, &y1, &x2, &y2);

    initgraph(&gd, &gm, "");

    rectangle(xmin, ymin, xmax, ymax);

    setcolor(RED);
    line(x1, y1, x2, y2);

    dx = x2 - x1;
    dy = y2 - y1;

    p[0] = -dx; q[0] = x1 - xmin;
    p[1] =  dx; q[1] = xmax - x1;
    p[2] = -dy; q[2] = y1 - ymin;
    p[3] =  dy; q[3] = ymax - y1;

    for(i = 0; i < 4; i++)
    {
        if(p[i] == 0 && q[i] < 0)
        {
            printf("Line completely outside");
            getch();
            closegraph();
            return 0;
        }

        if(p[i] != 0)
        {
            t = (float)q[i] / p[i];

            if(p[i] < 0)
            {
                if(t > t1) t1 = t;
            }
            else
            {
                if(t < t2) t2 = t;
            }
        }
    }

    if(t1 > t2)
    {
        printf("Line lies outside the window");
    }
    else
    {
        int xx1 = x1 + t1 * dx;
        int yy1 = y1 + t1 * dy;
        int xx2 = x1 + t2 * dx;
        int yy2 = y1 + t2 * dy;

        setcolor(YELLOW);
        line(xx1, yy1, xx2, yy2);
    }

    getch();
    closegraph();
    return 0;
}
