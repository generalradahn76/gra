#include <graphics.h>
#include <stdio.h>
#include <conio.h>
#include <math.h>

int main()
{
    int gd = DETECT, gm;
    int x1, y1, x2, y2;
    float dx, dy, steps, xInc, yInc, x, y;
    int i;

    printf("Enter starting coordinates (x1 y1): ");
    scanf("%d%d", &x1, &y1);

    printf("Enter ending coordinates (x2 y2): ");
    scanf("%d%d", &x2, &y2);

    initgraph(&gd, &gm, "");

    dx = x2 - x1;
    dy = y2 - y1;

    steps = (abs(dx) > abs(dy)) ? abs(dx) : abs(dy);

    xInc = dx / steps;
    yInc = dy / steps;

    x = x1;
    y = y1;

    for(i = 0; i <= steps; i++)
    {
        putpixel(round(x), round(y), WHITE);
        x += xInc;
        y += yInc;
    }

    getch();
    closegraph();

    return 0;
}
